# ============================================================
# Inkd Protocol — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── Deployer ─────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x...

# ── RPC Endpoints ────────────────────────────────────────────
BASE_RPC=https://mainnet.base.org
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ── Basescan API Key ─────────────────────────────────────────
# Get from https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here

# ── Post-Deploy (fill in after deployment) ───────────────────
INKD_TOKEN_ADDRESS=
INKD_TREASURY_PROXY=
INKD_TREASURY_IMPL=
INKD_REGISTRY_PROXY=
INKD_REGISTRY_IMPL=
DEPLOYER_ADDRESS=
DEPLOY_BLOCK=
DEPLOY_TX=
CHAIN_ID=8453
