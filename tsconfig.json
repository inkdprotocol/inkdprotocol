{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "declaration": true,
    "sourceMap": true
  },
  "references": [
    { "path": "./sdk" },
    { "path": "./system" },
    { "path": "./memory-system" }
  ],
  "exclude": [
    "node_modules",
    "dist",
    "contracts"
  ]
}
