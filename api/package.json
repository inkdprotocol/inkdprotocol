{
  "name": "@inkd/api",
  "version": "0.1.0",
  "description": "HTTP REST API server for Inkd Protocol \u2014 register projects, push versions, discover agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@irys/sdk": "^0.2.11",
    "@x402/core": "^2.5.0",
    "@x402/evm": "^2.5.0",
    "@x402/express": "^2.5.0",
    "@x402/fetch": "^2.5.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "supertest": "^7.2.2",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.6.2"
  }
}
