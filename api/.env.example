# ─── Inkd API Server — Environment Variables ──────────────────────────────────

# Port to listen on (default: 3000)
PORT=3000

# Network: mainnet (Base) or testnet (Base Sepolia)
INKD_NETWORK=testnet

# Custom RPC URL (optional — defaults to public Base/Base Sepolia endpoint)
# INKD_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Contract addresses (fill after deployment, see POST_DEPLOY.md)
INKD_TOKEN_ADDRESS=
INKD_REGISTRY_ADDRESS=
INKD_TREASURY_ADDRESS=

# API key for bearer token auth
# Leave empty to disable auth (local dev only — NEVER disable in production)
INKD_API_KEY=

# CORS allowed origin (default: * — restrict in production)
# CORS_ORIGIN=https://inkdprotocol.xyz

# Rate limiting (default: 60 requests per 60 seconds per IP)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=60
