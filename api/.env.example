# ─── Inkd API Server — Environment Variables ──────────────────────────────────

# Port to listen on (default: 3000)
PORT=3000

# Network: mainnet (Base) or testnet (Base Sepolia)
INKD_NETWORK=testnet

# Custom RPC URL (optional — defaults to public Base/Base Sepolia endpoint)
# INKD_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Contract addresses (fill after deployment, see POST_DEPLOY.md)
INKD_TOKEN_ADDRESS=
INKD_REGISTRY_ADDRESS=
INKD_TREASURY_ADDRESS=

# ─── x402 Payment Config (wallet = identity) ─────────────────────────────────
# The server wallet signs on-chain transactions on behalf of paying agents.
# Agents pay with their own wallets via x402 — no API keys needed.

# Server wallet private key (signs Registry/Treasury transactions)
SERVER_WALLET_KEY=0x...

# Server wallet address (receives x402 payments from agents)
SERVER_WALLET_ADDRESS=0x...

# Coinbase x402 facilitator URL (verifies payments)
X402_FACILITATOR_URL=https://x402.org/facilitator

# Set to 'false' to disable x402 and fall back to API key auth (dev only)
X402_ENABLED=true

# ─── Legacy API key auth (only used when X402_ENABLED=false) ─────────────────
# Leave empty to disable auth entirely in dev mode
INKD_API_KEY=

# ─── CORS + Rate Limiting ─────────────────────────────────────────────────────
# CORS_ORIGIN=https://inkdprotocol.xyz
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=60
