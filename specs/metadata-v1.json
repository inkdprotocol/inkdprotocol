{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inkdprotocol.com/specs/metadata-v1.json",
  "title": "Inkd Project Metadata",
  "description": "Extensible metadata schema for Inkd Protocol projects. Stored on Arweave, hash in metadataUri field of Registry.",
  "type": "object",
  "required": ["schema", "name"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "inkd/project/v1",
      "description": "Schema version identifier. Increment minor for backward-compatible additions."
    },
    "name": {
      "type": "string",
      "description": "Project name (matches on-chain normalized name)"
    },
    "description": {
      "type": "string",
      "description": "Full project description"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Searchable tags. keccak256(JSON.stringify(tags)) must match on-chain tagsHash."
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["infrastructure", "agent", "defi", "nft", "dao", "tool", "library", "dataset", "model", "other"]
      },
      "description": "Project categories for discovery"
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "Project homepage URL"
    },
    "repository": {
      "type": "string",
      "description": "Arweave hash or URL of the primary repository content"
    },
    "logo": {
      "type": "string",
      "description": "Arweave hash or IPFS/HTTPS URL of project logo"
    },
    "socials": {
      "type": "object",
      "properties": {
        "twitter": { "type": "string" },
        "discord": { "type": "string", "format": "uri" },
        "telegram": { "type": "string" },
        "github": { "type": "string", "format": "uri" }
      }
    },
    "agents": {
      "type": "array",
      "description": "Registered agent endpoints",
      "items": {
        "type": "object",
        "required": ["name", "endpoint"],
        "properties": {
          "name": { "type": "string" },
          "endpoint": { "type": "string", "format": "uri" },
          "capabilities": {
            "type": "array",
            "items": { "type": "string" },
            "description": "e.g. ['read', 'write', 'execute', 'sign']"
          },
          "schema": {
            "type": "string",
            "description": "Arweave hash of OpenAPI / AgentSchema JSON"
          }
        }
      }
    },
    "encryption": {
      "type": "object",
      "description": "Present only for private projects. Absence = public/unencrypted.",
      "required": ["scheme"],
      "properties": {
        "scheme": {
          "type": "string",
          "enum": ["ecies", "aes-gcm+ecies"],
          "description": "ecies = single recipient. aes-gcm+ecies = symmetric key wrapped per recipient."
        },
        "accessManifest": {
          "type": "string",
          "description": "Arweave hash of access manifest. Must match on-chain accessManifestHash."
        },
        "publicKey": {
          "type": "string",
          "description": "Owner ECIES public key (compressed secp256k1, hex)"
        }
      }
    },
    "build": {
      "type": "object",
      "description": "Build information",
      "properties": {
        "language": { "type": "string" },
        "runtime": { "type": "string" },
        "entrypoint": { "type": "string" },
        "packageManager": { "type": "string" }
      }
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier"
    },
    "createdAt": {
      "type": "integer",
      "description": "Unix timestamp (matches on-chain createdAt)"
    },
    "updatedAt": {
      "type": "integer",
      "description": "Unix timestamp of last metadata update"
    }
  },
  "additionalProperties": true,
  "_comment": "additionalProperties:true ensures forward compatibility — unknown fields are ignored by old parsers"
}
