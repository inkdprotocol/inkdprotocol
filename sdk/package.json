{
  "name": "@inkd/sdk",
  "version": "0.9.0",
  "description": "TypeScript SDK for Inkd Protocol — permanent on-chain file ownership on Base",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/index.mjs",
      "require": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "inkd",
    "protocol",
    "base",
    "blockchain",
    "arweave",
    "sdk",
    "web3",
    "ai-agents",
    "nft",
    "erc721",
    "inscription",
    "permanent-storage"
  ],
  "author": "Inkd Protocol <dev@inkdprotocol.xyz>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inkdprotocol/inkd-protocol.git",
    "directory": "sdk"
  },
  "homepage": "https://inkdprotocol.xyz",
  "bugs": {
    "url": "https://github.com/inkdprotocol/inkd-protocol/issues"
  },
  "peerDependencies": {
    "viem": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^10.0.2",
    "typescript": "^5.0.0",
    "viem": "^2.0.0",
    "vitest": "^1.6.1"
  }
}
