# ─── Required for Deploy ──────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x...

# ─── RPC Endpoints ───────────────────────────────────────────────────
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_RPC=https://mainnet.base.org

# ─── Contract Verification ────────────────────────────────────────────
BASESCAN_API_KEY=...

# ─── SDK / App ────────────────────────────────────────────────────────
# After deploy, fill in the proxy addresses from the deployment output
NEXT_PUBLIC_TOKEN_ADDRESS=0x...
NEXT_PUBLIC_VAULT_ADDRESS=0x...
NEXT_PUBLIC_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_CHAIN_ID=84532

# ─── Arweave (for inscriptions) ───────────────────────────────────────
# Get a JWK key from https://arweave.net
ARWEAVE_PRIVATE_KEY={"kty":"RSA",...}

# ─── Lit Protocol (optional, for encrypted inscriptions) ──────────────
LIT_PRIVATE_KEY=0x...
